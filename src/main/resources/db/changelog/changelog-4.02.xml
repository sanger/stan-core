<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">

    <changeSet id="4.2.0" author="dr6">
        <createTable tableName="treatment_type">
            <column name="id" type="INT" autoIncrement="true">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="name" type="VARCHAR(64)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="enabled" type="BOOLEAN" defaultValue="true">
                <constraints nullable="false"/>
            </column>
            <column name="created" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated" type="TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="4.2.1" author="dr6">
        <createTable tableName="work_treatment_type">
            <column name="work_id" type="INT">
                <constraints nullable="false" foreignKeyName="fk_work_treatment_type_work" referencedTableName="work" referencedColumnNames="id"/>
            </column>
            <column name="treatment_type_id" type="INT">
                <constraints nullable="false" foreignKeyName="fk_work_treatment_type_treatment_type" referencedTableName="treatment_type" referencedColumnNames="id"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="work_treatment_type" columnNames="work_id,treatment_type_id"/>
        <rollback>
            <dropAllForeignKeyConstraints baseTableName="work_treatment_type"/>
            <dropTable tableName="work_treatment_type"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
